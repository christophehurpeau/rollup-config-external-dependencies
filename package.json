{
  "name": "rollup-config-external-dependencies",
  "version": "3.0.1",
  "description": "rollup config external dependencies",
  "keywords": [],
  "homepage": "https://github.com/christophehurpeau/rollup-config-external-dependencies",
  "bugs": {
    "url": "https://github.com/christophehurpeau/rollup-config-external-dependencies/issues"
  },
  "license": "ISC",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (http://christophe.hurpeau.com/)",
  "repository": "https://github.com/christophehurpeau/rollup-config-external-dependencies.git",
  "files": [
    "lib"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "exports": {
    ".": "./lib/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "checks": "node scripts/check-package.js",
    "format": "oxfmt",
    "format:check": "oxfmt --check .",
    "generate:test-coverage": "rm -Rf docs/coverage/ ; NODE_ENV=production BABEL_ENV=test jest --coverage --coverageReporters=pob-lcov-reporter --coverageDirectory=docs/coverage/",
    "lint": "pnpm run format && pnpm run lint:eslint",
    "lint:eslint": "eslint --quiet .",
    "prepare": "pob-root-postinstall",
    "test": "TZ=UTC node --test lib/**/*.test.js",
    "test:coverage": "TZ=UTC npx c8 --all --src ./lib node --test lib/**/*.test.js",
    "test:coverage:json": "TZ=UTC npx c8 --reporter=json --all --src ./lib node --test lib/**/*.test.js",
    "test:watch": "TZ=UTC node --test lib/**/*.test.js"
  },
  "devDependencies": {
    "@pob/eslint-config": "65.4.3",
    "@pob/root": "24.3.0",
    "check-package-dependencies": "11.1.1",
    "eslint": "10.5.0"
  },
  "commitlint": {
    "extends": [
      "@pob/root/commitlint-config"
    ]
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "pob": {}
}
